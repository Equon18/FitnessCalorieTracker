@{
    ViewData["Title"] = "Home Page";
}

<div class="text-center">
    <h1 class="display-4">Welcome to Fitness & Calorie Tracker</h1>
    <p class="lead">Track your workouts, calories, and daily goals all in one place.</p>

    <hr />

    <div class="list-group">
        <a asp-controller="User" asp-action="Index" class="list-group-item list-group-item-action">User Profile</a>
        <a asp-controller="Calorie" asp-action="Index" class="list-group-item list-group-item-action">Calorie Tracking</a>
        <a asp-controller="Workout" asp-action="Index" class="list-group-item list-group-item-action">Workout Tracking</a>
        <a asp-controller="Summary" asp-action="Index" class="list-group-item list-group-item-action">Daily Summary</a>
        <a asp-controller="Reminder" asp-action="Index" class="list-group-item list-group-item-action">Reminders</a>
    </div>
</div>
