@model FitnessAndCalorieTracker.Models.CalorieEntry
@{
    ViewData["Title"] = "Delete Calorie Entry";
}

<h2>Delete Calorie Entry</h2>

<h4>Are you sure you want to delete this entry?</h4>
<hr />

<dl class="row">
    <dt class="col-sm-3">Food Name</dt>
    <dd class="col-sm-9">@Model.FoodName</dd>

    <dt class="col-sm-3">Calories</dt>
    <dd class="col-sm-9">@Model.Calories</dd>

    <dt class="col-sm-3">Date</dt>
    <dd class="col-sm-9">@Model.Date.ToShortDateString()</dd>
</dl>

<form asp-action="DeleteConfirmed">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
