@model IEnumerable<FitnessAndCalorieTracker.Models.User>

@{
    ViewData["Title"] = "User List";
}

<h2 class="mt-4">User List</h2>

@if (Model == null || !Model.Any())
{
    <p>No users found.</p>
}
else
{
    <table class="table table-bordered table-striped mt-3">
        <thead>
            <tr>
                <th>Name</th>
                <th>Age</th>
                <th>Height (cm)</th>
                <th>Weight (kg)</th>
                <th>Daily Calorie Goal</th>
                <th>BMI</th>
                <th style="width: 200px;"></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model)
            {
                <tr>
                    <td>@user.Name</td>
                    <td>@user.Age</td>
                    <td>@user.Height</td>
                    <td>@user.Weight</td>
                    <td>@user.DailyCalorieGoal</td>
                    <td>@user.BMI</td>
                    <td>
                        <a asp-action="Details" asp-route-id="@user.Id" class="btn btn-sm btn-info">Details</a>
                        <a asp-action="Edit" asp-route-id="@user.Id" class="btn btn-sm btn-primary">Edit</a>
                        <a asp-action="Delete" asp-route-id="@user.Id" class="btn btn-sm btn-danger">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

<a asp-controller="User" asp-action="Create" class="btn btn-success mt-3">
    Create New User
</a>

