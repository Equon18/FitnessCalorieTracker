@model FitnessAndCalorieTracker.Models.User
@{
    ViewData["Title"] = "Delete User";
}

<h2>Delete User Profile</h2>

<h4>Are you sure you want to delete this user?</h4>
<hr />

<dl class="row">
    <dt class="col-sm-3">Name</dt>
    <dd class="col-sm-9">@Model.Name</dd>

    <dt class="col-sm-3">Age</dt>
    <dd class="col-sm-9">@Model.Age</dd>

    <dt class="col-sm-3">Height</dt>
    <dd class="col-sm-9">@Model.Height</dd>

    <dt class="col-sm-3">Weight</dt>
    <dd class="col-sm-9">@Model.Weight</dd>

    <dt class="col-sm-3">Daily Calorie Goal</dt>
    <dd class="col-sm-9">@Model.DailyCalorieGoal</dd>
</dl>

<form asp-action="DeleteConfirmed">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
