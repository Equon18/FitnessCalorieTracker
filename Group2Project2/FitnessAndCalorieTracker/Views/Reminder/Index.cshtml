@model IEnumerable<FitnessAndCalorieTracker.Models.Reminder>
@{
    ViewData["Title"] = "Reminders";
}

<h2>Reminders</h2>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Title</th>
            <th>Description</th>
            <th>Reminder Time</th>
            <th>Status</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var reminder in Model)
        {
            <tr>
                <td>@reminder.Title</td>
                <td>@reminder.Description</td>
                <td>@reminder.ReminderTime.ToString("g")</td>
                <td>
                    @if (reminder.IsComplete)
                    {
                        <span class="text-success">Completed</span>
                    }
                    else
                    {
                        <span class="text-danger">Pending</span>
                    }
                </td>
                <td>
                    @if (!reminder.IsComplete)
                    {
                        <a asp-action="Complete" asp-route-id="@reminder.Id" class="btn btn-sm btn-success">Mark Complete</a>
                    }
                    <a asp-action="Delete" asp-route-id="@reminder.Id" class="btn btn-sm btn-danger">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>

<a asp-action="Create" class="btn btn-primary">Add Reminder</a>
