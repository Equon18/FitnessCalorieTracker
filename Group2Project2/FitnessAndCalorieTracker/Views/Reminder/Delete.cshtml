@model FitnessAndCalorieTracker.Models.Reminder
@{
    ViewData["Title"] = "Delete Reminder";
}

<h2>Delete Reminder</h2>

<h4>Are you sure you want to delete this reminder?</h4>
<hr />

<dl class="row">
    <dt class="col-sm-3">Title</dt>
    <dd class="col-sm-9">@Model.Title</dd>

    <dt class="col-sm-3">Description</dt>
    <dd class="col-sm-9">@Model.Description</dd>

    <dt class="col-sm-3">Reminder Time</dt>
    <dd class="col-sm-9">@Model.ReminderTime.ToString("g")</dd>

    <dt class="col-sm-3">Status</dt>
    <dd class="col-sm-9">
        @(Model.IsComplete ? "Completed" : "Pending")
    </dd>
</dl>

<form asp-action="DeleteConfirmed">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
